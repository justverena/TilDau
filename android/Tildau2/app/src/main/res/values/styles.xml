<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ProgressBarCircle">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:background">@drawable/progress_item_base</item>
    </style>

    <style name="DayLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#EDE7F6</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DayCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_day_circle</item>
    </style>
</resources>