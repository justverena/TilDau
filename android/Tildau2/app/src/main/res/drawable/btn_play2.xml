<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. БОЛЬШОЙ ФИОЛЕТОВЫЙ КРУГ -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/main_purple"/>
        </shape>
    </item>

    <!-- 2. БЕЛЫЙ КРУГ ВНУТРИ -->
    <item
        android:gravity="center"
        android:width="48dp"
        android:height="48dp">

        <shape android:shape="oval">
            <solid android:color="@color/white"/>
        </shape>
    </item>

    <!-- 3. ИКОНКА В ЦЕНТРЕ -->
    <item
        android:drawable="@drawable/ic_play_filled"
        android:gravity="center"
        android:width="16dp"
        android:height="16dp"/>

</layer-list>