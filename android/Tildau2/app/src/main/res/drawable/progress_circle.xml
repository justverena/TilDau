<rotate xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromDegrees="-90"
    android:toDegrees="270">

    <!-- незаполненная часть (background) -->
    <shape
        android:shape="ring"
        android:useLevel="true"
        android:thickness="2dp"
        android:innerRadiusRatio="3.5">
        <solid android:color="#FFFFFFFF"/> <!-- белая незаполненная часть -->
    </shape>

    <!-- заполненная часть (progress) -->
    <shape
        android:shape="ring"
        android:useLevel="true"
        android:thickness="4dp"
        android:innerRadiusRatio="3.5">
        <solid android:color="@color/text_dark"/> <!-- темная заполненная часть -->
    </shape>
</rotate>