<rotate xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromDegrees="-90"
    android:toDegrees="270">

    <!-- незаполненная часть (background) -->
    <shape
        android:shape="ring"
        android:useLevel="true"
        android:thickness="25dp"
        android:innerRadiusRatio="3.5">

        <solid android:color="@color/black"/>
    </shape>

    <!-- заполненная часть (progress) -->
    <shape
        android:shape="ring"
        android:useLevel="true"
        android:thickness="16dp"
        android:innerRadiusRatio="3.5">

        <gradient
            android:startColor="#6344D4"
            android:endColor="#666344D4"
            android:angle="45"
            />

    </shape>
</rotate>