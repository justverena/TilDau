<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="0dp"
    android:layout_marginStart="8dp">


    <View
        android:id="@+id/line1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/gray"
        app:layout_constraintStart_toStartOf="@id/practiceDot"
        app:layout_constraintEnd_toEndOf="@id/practiceDot"
        app:layout_constraintTop_toTopOf="parent"
        />

    <!-- маленький кружок -->
    <View
        android:id="@+id/practiceDot"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_dot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/line1"/>

    <!-- линия вниз -->
    <View
        android:layout_width="2dp"
        android:layout_height="10dp"
        android:background="@color/gray"
        app:layout_constraintStart_toStartOf="@id/practiceDot"
        app:layout_constraintEnd_toEndOf="@id/practiceDot"
        app:layout_constraintTop_toBottomOf="@id/practiceDot"/>

    <!-- текст -->
    <TextView
        android:id="@+id/exerciseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Practice"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/practiceDot"
        app:layout_constraintTop_toTopOf="@id/practiceDot"
        android:layout_marginStart="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>