<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="13dp"
        android:background="@drawable/bg_gradient_card1">

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Бұл бөлімде қосымшада орындауға болатын барлық жетістіктер көрсетілген. Әр жетістік оқу барысындағы белгілі бір мақсатқа қол жеткізуді білдіреді."
            android:textColor="#F2EEFF"
            android:textSize="15sp"
            android:textStyle="bold"
            />




    </LinearLayout>

</androidx.cardview.widget.CardView>