<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <!-- HEADER -->
    <TextView
        android:id="@+id/tvSkillsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Skills"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#1C1C1E"
        android:paddingBottom="10dp"/>

    <!-- CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/skillsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_light_purple">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="13dp">

            <!-- FLUENCY -->
            <TextView
                android:id="@+id/tvFluency"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="Fluency: 0"
                android:textStyle="bold"
                android:textSize="17dp"
                android:background="@drawable/bg_skill_row_progress"
                android:textColor="#1C1C1E"
                android:layout_marginBottom="8dp"/>

            <!-- PRONUNCIATION -->
            <TextView
                android:id="@+id/tvPronunciation"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="Pronunciation: 0"
                android:textStyle="bold"
                android:textSize="17dp"
                android:background="@drawable/bg_skill_row_progress"
                android:textColor="#1C1C1E"
                android:layout_marginBottom="8dp"/>

            <!-- OVERALL -->
            <TextView
                android:id="@+id/tvOverall"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="Overall: 0"
                android:textStyle="bold"
                android:textSize="17dp"
                android:background="@drawable/bg_skill_row_progress"
                android:textColor="#1C1C1E"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>