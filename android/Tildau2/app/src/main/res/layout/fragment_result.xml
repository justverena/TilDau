<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Results"
            android:layout_marginStart="8dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>
    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- SCORE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="40dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/bg_score_card"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="170dp"
                    android:layout_height="170dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/circle_progress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:progress="91"
                        android:max="100"
                        android:indeterminate="false"
                        app:indicatorSize="160dp"
                        app:trackThickness="10dp"
                        app:indicatorColor="#000000"
                        app:trackColor="#E0E0E0"
                        android:rotation="-90"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/score_number"
                            android:text="91"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/score_label"
                            android:text="SCORE"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="@color/text_muted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/result_status"
                    android:text="Excellent"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/feedback_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Пример одной карточки инсайта -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_insight_card"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:text="✨"
                                android:layout_marginEnd="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="AI PERSONALIZED INSIGHTS"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:textColor="@color/main_purple"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <TextView
                            android:text="Your pronunciation of 'th' sounds was spot on!"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="To reach 100, try to maintain a more consistent pace between sentences to improve your overall rhythm and flow."
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Можно добавлять новые карточки динамически в ResultFragment -->
                </LinearLayout>
            </ScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/next_lesson_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next Lesson"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_primary_button"
            android:padding="16dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/retry_practice_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="↺  Retry Practice"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/main_purple"
            android:background="@drawable/bg_secondary_button"
            android:padding="16dp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>