<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/unitCard"
    android:layout_width="match_parent"
    android:layout_height="82dp"
    android:layout_marginBottom="16dp"
    android:backgroundTint="#F9F9FB"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E7E7EB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Круг с номером -->
        <FrameLayout
            android:id="@+id/numberContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/unitNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#353546"/>
        </FrameLayout>

        <!-- Заголовок -->
        <TextView
            android:id="@+id/unitTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/numberContainer"
            app:layout_constraintTop_toTopOf="@id/numberContainer"
            app:layout_constraintEnd_toStartOf="@id/stateIcon"/>

        <!-- Нижняя строка (статус) -->
        <LinearLayout
            android:id="@+id/statusContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/numberContainer"
            app:layout_constraintBottom_toBottomOf="@id/numberContainer">

            <TextView
                android:id="@+id/statusPrimary"
                android:textSize="10sp"
                android:textStyle="italic"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/statusSecondary"
                android:textSize="10sp"
                android:textStyle="italic"
                android:textColor="#000000"
                android:layout_marginStart="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Иконка справа -->
        <ImageView
            android:id="@+id/stateIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
