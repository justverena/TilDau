<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    android:backgroundTint="#9C7BFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="March, 2025"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Just 2 more days to hit your weekly goal."
            android:textColor="#EDE7F6"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <!-- Дни недели -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:layout_marginTop="12dp">

            <TextView style="@style/DayLabel" android:text="MO"/>
            <TextView style="@style/DayLabel" android:text="TU"/>
            <TextView style="@style/DayLabel" android:text="WE"/>
            <TextView style="@style/DayLabel" android:text="TH"/>
            <TextView style="@style/DayLabel" android:text="FR"/>
            <TextView style="@style/DayLabel" android:text="SA"/>
            <TextView style="@style/DayLabel" android:text="SU"/>

        </GridLayout>

        <!-- Календарь -->
        <GridLayout
            android:id="@+id/calendarGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:layout_marginTop="8dp">

            <!-- Пример дня -->
            <!-- Пустой -->
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>
            <FrameLayout style="@style/DayCell"/>

            <!-- День со streak -->
            <FrameLayout style="@style/DayCell">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_streak_on"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <!-- День с числом -->
            <FrameLayout style="@style/DayCell">
                <TextView
                    android:text="1"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </FrameLayout>

            <!-- Скопируй такие блоки 42 раза (6 строк × 7 колонок) -->

        </GridLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>