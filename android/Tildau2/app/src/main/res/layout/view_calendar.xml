<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    android:backgroundTint="#9C7BFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- МЕСЯЦ -->
        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="April, 2026"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- ПОДЗАГОЛОВОК -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Just 2 more days to hit your weekly goal."
            android:textColor="#EDE7F6"
            android:textSize="10sp"
            android:layout_marginTop="4dp" />

        <!-- ДНИ НЕДЕЛИ -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:layout_marginTop="12dp">

            <TextView style="@style/DayLabel" android:text="MO"/>
            <TextView style="@style/DayLabel" android:text="TU"/>
            <TextView style="@style/DayLabel" android:text="WE"/>
            <TextView style="@style/DayLabel" android:text="TH"/>
            <TextView style="@style/DayLabel" android:text="FR"/>
            <TextView style="@style/DayLabel" android:text="SA"/>
            <TextView style="@style/DayLabel" android:text="SU"/>
        </GridLayout>

        <!-- КАЛЕНДАРЬ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/calendarGrid"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_calendar_day"
            tools:itemCount="14"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>