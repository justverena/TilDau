<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_card1"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnPrevWeek"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_chevron_left"
                app:tint="@android:color/white"/>

            <TextView
                android:id="@+id/tvWeekMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Ай мен жыл"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnNextWeek"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@android:color/white"/>

        </LinearLayout>


        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:layout_marginTop="12dp">

            <TextView style="@style/DayLabel" android:text="ДС"/>
            <TextView style="@style/DayLabel" android:text="СС"/>
            <TextView style="@style/DayLabel" android:text="СР"/>
            <TextView style="@style/DayLabel" android:text="БС"/>
            <TextView style="@style/DayLabel" android:text="ЖМ"/>
            <TextView style="@style/DayLabel" android:text="СБ"/>
            <TextView style="@style/DayLabel" android:text="ЖС"/>

        </GridLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWeekCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>